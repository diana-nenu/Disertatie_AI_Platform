# Copiază acest fișier ca .env și completează valorile
# .env NU se urcă pe GitHub (este în .gitignore)

# HuggingFace token (necesar pentru modele private sau rate limiting mai mare)
HUGGINGFACE_TOKEN=hf_your_token_here

# Opțional: alte chei API
# OPENAI_API_KEY=sk-...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
