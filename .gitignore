# =============================================================
# Date mari (NU urcăm pe GitHub)
# =============================================================
# Ținem doar fișiere mai mici pentru reproducibilitate, restul în cloud/local
data/raw/*.csv
data/processed/*.csv
data/processed/*.parquet
data/external/

# Excepție: păstrăm un README în data/
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# =============================================================
# Modele antrenate (mari și regenerabile)
# =============================================================
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.pth
models/*.onnx
!models/.gitkeep

